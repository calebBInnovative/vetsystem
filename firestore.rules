rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // DEV MODE — open access until July 28, 2026.
    // Replace with proper rules before going to production with real users.
    match /{document=**} {
      allow read, write: if request.time < timestamp.date(2026, 7, 28);
    }
  }
}
